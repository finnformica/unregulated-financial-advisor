# YouTube Data API v3 key — used by scrapers/youtube.py to list videos and fetch metadata
YOUTUBE_API_KEY=your_youtube_data_api_v3_key

# Lyn Alden paid-blog credentials — used by scrapers/lyn_alden_blog.py for Playwright login
LYN_ALDEN_USERNAME=your_lynalden_username
LYN_ALDEN_PASSWORD=your_lynalden_password

# Ollama server (local) — base URL and model names used by ingest.py and council.py
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.1:8b

# ChromaDB persistent store path — created on first ingest run
CHROMA_PATH=./chroma_db

# HTTP Basic Auth credentials for the council web UI (app.py)
COUNCIL_USER=your_username
COUNCIL_PASSWORD=your_password
